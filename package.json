{
  "name": "greenclaw",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:gateway\" \"pnpm --filter frontend dev\"",
    "dev:gateway": "pnpm --filter backend dev",
