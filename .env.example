# ===== Project =====
PROJECT_NAME=GreenClaw
PROJECT_ENV=development

# ===== Ports =====
FRONTEND_PORT=3000
BACKEND_PORT=4000
CALC_ENGINE_PORT=8000
REDIS_PORT=6379
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_PORT=80

# ===== Reverse Proxy (Nginx) =====
NGINX_SERVER_NAME=_
FRONTEND_UPSTREAM=http://frontend:3000
BACKEND_UPSTREAM=http://backend:4000

# ===== LLM (Gateway / Agent) =====
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# ===== Backend / Memory =====
MEMORY_PROVIDER=sqlite
MEMORY_SQLITE_PATH=./data/greenclaw.db
VECTOR_STORE_PROVIDER=local
VECTOR_STORE_PATH=./data/vector-store

# ===== Calc Engine =====
GB_RULESET_VERSION=GB_T_50378_2019
ENERGYPLUS_PATH=
PYTHON_LOG_LEVEL=info

# ===== Security =====
JWT_SECRET=replace_me_with_a_strong_secret
ENCRYPTION_KEY=replace_me_with_32_bytes_key
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
COOKIE_SECURE=false
FRONTEND_ORIGIN=http://localhost
NEXT_PUBLIC_API_BASE_URL=http://localhost
ACCESS_COOKIE_NAME=gc_access
REFRESH_COOKIE_NAME=gc_refresh

# ===== Feature Flags =====
ENABLE_AGENT_HEARTBEAT=true
ENABLE_REPORT_EXPORT=true
ENABLE_EPLUS_AUTOMATION=false
