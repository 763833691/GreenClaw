# ===== Base Runtime =====
NODE_ENV=production
PROJECT_ENV=production
ENABLE_LOCAL_LISTEN=true

# ===== Public Entrypoint =====
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
DOMAIN=localhost
FRONTEND_ORIGIN=https://localhost
NEXT_PUBLIC_API_BASE_URL=https://localhost
NEXT_PUBLIC_API_BASE=https://localhost
NEXT_PUBLIC_GATEWAY_URL=https://localhost
NEXT_PUBLIC_CALC_API_BASE_URL=https://localhost

# ===== TLS / HTTPS =====
TLS_CERT_PATH=./infra/nginx/certs/fullchain.pem
TLS_KEY_PATH=./infra/nginx/certs/privkey.pem

# ===== Gateway / Backend =====
PORT=18789
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
COOKIE_SECURE=true
ACCESS_COOKIE_NAME=gc_access
REFRESH_COOKIE_NAME=gc_refresh
CALC_ENGINE_URL=http://python-calculator:8000

# ===== Redis =====
REDIS_PORT=6379
REDIS_PASSWORD=replace_with_strong_random_password_at_least_24_chars
REDIS_URL=redis://:replace_with_redis_password@redis:6379

# ===== LLM / OpenClaw Agent =====
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
MEMORY_PROVIDER=sqlite
MEMORY_SQLITE_PATH=/workspace/data/greenclaw.db
VECTOR_STORE_PROVIDER=local
VECTOR_STORE_PATH=/workspace/data/vector-store
ENABLE_AGENT_HEARTBEAT=true
HEARTBEAT_INTERVAL_MS=86400000

# ===== Python Calculator =====
PYTHON_LOG_LEVEL=warning
GB_RULESET_VERSION=GB_T_50378_2019
ENERGYPLUS_PATH=

# ===== Environment Profiles =====
# Development:
#   NODE_ENV=development
#   COOKIE_SECURE=false
#   FRONTEND_ORIGIN=http://localhost
#   NEXT_PUBLIC_API_BASE_URL=http://localhost
#   NEXT_PUBLIC_CALC_API_BASE_URL=http://localhost:8000
#
# Production:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
